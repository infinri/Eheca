{% extends 'base.html.twig' %}

{% block title %}Password Reset Email Sent{% endblock %}

{% block body %}
    <div class="auth-container text-center">
        <div class="mb-4">
            <div class="icon-large text-primary mb-3">
                <i class="bi bi-envelope-check" style="font-size: 3.5rem;"></i>
            </div>
            <h1 class="h3 mb-3 font-weight-normal">Check Your Email</h1>
            <p class="text-muted">We've sent you a password reset link</p>
        </div>
        
        <div class="alert alert-info text-start">
            <div class="d-flex">
                <div class="flex-shrink-0 me-3">
                    <i class="bi bi-info-circle-fill"></i>
                </div>
                <div>
                    <p class="mb-2">An email has been sent to <strong>{{ resetToken.user.email }}</strong> with instructions to reset your password.</p>
                    <p class="mb-0">This link will expire in <strong>{{ tokenLifetime|date('g') }} hour(s)</strong>.</p>
                </div>
            </div>
        </div>
        
        <div class="card border-light mb-4">
            <div class="card-body">
                <h5 class="card-title">Didn't receive the email?</h5>
                <ol class="text-start ps-3 mb-0">
                    <li class="mb-2">Check your spam or junk folder</li>
                    <li class="mb-2">Make sure the email address is correct</li>
                    <li class="mb-0">
                        <a href="{{ path('app_forgot_password_request') }}" class="text-decoration-none">
                            <i class="bi bi-arrow-clockwise me-1"></i>Send again
                        </a>
                    </li>
                </ol>
            </div>
        </div>
        
        <div class="mt-4">
            <a href="{{ path('app_login') }}" class="btn btn-outline-primary">
                <i class="bi bi-arrow-left me-2"></i>Back to login
            </a>
        </div>
    </div>
    
    <style>
    .icon-large {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 80px;
        height: 80px;
        border-radius: 50%;
        background-color: rgba(79, 70, 229, 0.1);
        margin: 0 auto 1.5rem;
    }
    
    .card {
        border: none;
        box-shadow: 0 0.125rem 0.25rem rgba(0, 0, 0, 0.075);
    }
    
    .alert {
        border: none;
        background-color: #f8f9fa;
    }
    
    .alert-info {
        color: #055160;
        background-color: #cff4fc;
        border-color: #b6effb;
    }
    </style>
{% endblock %}
