{% extends 'email/base.html.twig' %}

{% block email_title %}Reset Your Password{% endblock %}

{% block body %}
    <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%">
        <tr>
            <td style="padding: 20px 0; text-align: center;">
                <h1 style="margin: 0; font-size: 24px; font-weight: 600; color: #2d3748;">
                    Reset Your Password
                </h1>
            </td>
        </tr>
        <tr>
            <td style="padding: 20px 0;">
                <p style="margin: 0 0 20px 0; font-size: 16px; line-height: 1.6; color: #4a5568;">
                    Hello,
                </p>
                <p style="margin: 0 0 20px 0; font-size: 16px; line-height: 1.6; color: #4a5568;">
                    We received a request to reset the password for your account. To complete the process, please click the button below:
                </p>
                
                <!-- Button -->
                <table role="presentation" cellspacing="0" cellpadding="0" border="0" style="margin: 32px auto;">
                    <tr>
                        <td style="background: #4f46e5; border-radius: 6px;" align="center">
                            <a href="{{ url('app_reset_password', {token: resetToken.token}) }}" target="_blank" style="background: #4f46e5; color: #ffffff; font-family: 'Inter', Arial, sans-serif; font-size: 15px; font-weight: 600; line-height: 44px; text-decoration: none; padding: 0 24px; display: inline-block; border-radius: 6px;">
                                Reset Password
                            </a>
                        </td>
                    </tr>
                </table>
                
                <p style="margin: 20px 0 0 0; font-size: 14px; line-height: 1.5; color: #718096;">
                    Or copy and paste this link into your browser:
                </p>
                <p style="margin: 8px 0 0 0; font-size: 14px; line-height: 1.5; word-break: break-all; color: #4a5568;">
                    <a href="{{ url('app_reset_password', {token: resetToken.token}) }}" style="color: #4f46e5; text-decoration: none;" target="_blank">
                        {{ url('app_reset_password', {token: resetToken.token}) }}
                    </a>
                </p>
                
                <p style="margin: 24px 0 0 0; font-size: 14px; line-height: 1.5; color: #e53e3e;">
                    <strong>Note:</strong> This link will expire in {{ tokenLifetime|date('g') }} hour(s).
                </p>
                
                <p style="margin: 24px 0 0 0; font-size: 14px; line-height: 1.5; color: #4a5568;">
                    If you didn't request this email, you can safely ignore it. Your password won't be changed until you access the link above and create a new one.
                </p>
                
                <p style="margin: 24px 0 0 0; font-size: 14px; line-height: 1.5; color: #4a5568;">
                    Thanks,<br>
                    The {{ app_name }} Team
                </p>
            </td>
        </tr>
    </table>
    
    <!-- Footer -->
    <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%" style="margin-top: 40px; padding-top: 20px; border-top: 1px solid #e2e8f0;">
        <tr>
            <td style="text-align: center; padding: 10px 0;">
                <p style="margin: 0; font-size: 12px; line-height: 1.5; color: #a0aec0;">
                    &copy; {{ 'now'|date('Y') }} {{ app_name }}. All rights reserved.
                </p>
                <p style="margin: 4px 0 0 0; font-size: 12px; line-height: 1.5; color: #a0aec0;">
                    This is an automated message, please do not reply to this email.
                </p>
            </td>
        </tr>
    </table>
{% endblock %}
