<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>{% block title %}Welcome!{% endblock %}</title>
    <style>
        body { font-family: Arial, sans-serif; line-height: 1.6; color: #333; max-width: 600px; margin: 0 auto; padding: 20px; }
        .email-container { background-color: #f9f9f9; padding: 20px; border-radius: 5px; }
        .email-header { text-align: center; margin-bottom: 20px; }
        .email-body { background-color: #fff; padding: 20px; border-radius: 5px; }
        .email-footer { margin-top: 20px; font-size: 12px; color: #666; text-align: center; }
        .button { 
            display: inline-block; 
            padding: 10px 20px; 
            background-color: #007bff; 
            color: #fff; 
            text-decoration: none; 
            border-radius: 5px; 
            margin: 10px 0;
        }
    </style>
</head>
<body>
    <div class="email-container">
        <div class="email-header">
            <h1>{% block email_title %}{% endblock %}</h1>
        </div>
        <div class="email-body">
            {% block body %}{% endblock %}
        </div>
        <div class="email-footer">
            <p>This is an automated message, please do not reply to this email.</p>
            <p>&copy; {{ "now"|date("Y") }} Your Company. All rights reserved.</p>
        </div>
    </div>
</body>
</html>
