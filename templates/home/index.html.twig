{% extends 'base.html.twig' %}

{% block title %}Eheca Framework - Modern PHP Framework{% endblock %}

{% block body %}
    <!-- Hero Section -->
    <section class="py-20 bg-gradient-to-br from-blue-50 to-indigo-50">
        <div class="container mx-auto px-6 text-center">
            <div class="max-w-4xl mx-auto">
                <span class="inline-block px-4 py-2 text-sm font-semibold text-blue-700 bg-blue-100 rounded-full mb-6">
                    v1.0.0 Released
                </span>
                <h1 class="text-5xl md:text-6xl font-bold text-gray-900 mb-6">
                    The Modern PHP Framework
                    <span class="text-blue-600">You've Been Waiting For</span>
                </h1>
                <p class="text-xl text-gray-600 mb-10 max-w-2xl mx-auto">
                    Eheca is a high-performance PHP framework that makes web development a breeze. 
                    Built with modern best practices and designed for developer happiness.
                </p>
                <div class="flex flex-col sm:flex-row justify-center gap-4 mb-16">
                    <a href="#get-started" class="inline-block bg-blue-600 hover:bg-blue-700 text-white font-semibold py-3 px-8 rounded-lg transition duration-300 transform hover:-translate-y-1">
                        Get Started
                    </a>
                    <a href="#features" class="inline-block bg-white hover:bg-gray-50 text-gray-800 font-semibold py-3 px-8 border border-gray-300 rounded-lg transition duration-300 transform hover:-translate-y-1">
                        Learn More
                    </a>
                </div>
                <div class="relative max-w-4xl mx-auto rounded-xl shadow-xl overflow-hidden bg-white">
                    <div class="bg-gray-800 h-8 flex items-center px-4">
                        <div class="w-3 h-3 rounded-full bg-red-500 mr-2"></div>
                        <div class="w-3 h-3 rounded-full bg-yellow-500 mr-2"></div>
                        <div class="w-3 h-3 rounded-full bg-green-500"></div>
                    </div>
                    <div class="p-6 bg-gray-900 text-gray-300 font-mono text-sm overflow-x-auto">
                        <div class="mb-2">
                            <span class="text-green-400">$</span> composer create-project eheca/framework my-app
                        </div>
                        <div class="mb-2">
                            <span class="text-green-400">$</span> cd my-app
                        </div>
                        <div class="mb-2">
                            <span class="text-green-400">$</span> php bin/console server:run
                        </div>
                        <div>
                            <span class="text-blue-400">[OK] Server listening on http://127.0.0.1:8000</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Features Section -->
    <section id="features" class="py-20 bg-white">
        <div class="container mx-auto px-6">
            <div class="text-center mb-16">
                <h2 class="text-4xl font-bold text-gray-900 mb-4">Powerful Features</h2>
                <div class="w-20 h-1 bg-blue-600 mx-auto"></div>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
                {% for feature in features %}
                <div class="bg-white p-8 rounded-xl shadow-lg hover:shadow-xl transition-shadow duration-300">
                    <div class="text-4xl mb-4">{{ feature.icon }}</div>
                    <h3 class="text-xl font-semibold mb-3 text-gray-900">{{ feature.title }}</h3>
                    <p class="text-gray-600">{{ feature.description }}</p>
                </div>
                {% endfor %}
            </div>
        </div>
    </section>

    <!-- CTA Section -->
    <section class="py-20 bg-gray-50">
        <div class="container mx-auto px-6 text-center">
            <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-6">Ready to get started?</h2>
            <p class="text-xl text-gray-600 mb-10 max-w-2xl mx-auto">
                Join thousands of developers building amazing applications with Eheca Framework.
            </p>
            <div class="flex flex-col sm:flex-row justify-center gap-4">
                <a href="#" class="inline-block bg-blue-600 hover:bg-blue-700 text-white font-semibold py-3 px-8 rounded-lg transition duration-300 transform hover:-translate-y-1">
                    Get Started
                </a>
                <a href="#" class="inline-flex items-center justify-center text-blue-600 hover:text-blue-700 font-semibold py-3 px-8">
                    View Documentation
                    <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                    </svg>
                </a>
            </div>
        </div>
    </section>

    <!-- Stats Section -->
    <section class="py-16 bg-white">
        <div class="container mx-auto px-6">
            <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
                <div class="p-6">
                    <div class="text-4xl font-bold text-blue-600 mb-2">10K+</div>
                    <div class="text-gray-600">Downloads</div>
                </div>
                <div class="p-6">
                    <div class="text-4xl font-bold text-blue-600 mb-2">100%</div>
                    <div class="text-gray-600">Open Source</div>
                </div>
                <div class="p-6">
                    <div class="text-4xl font-bold text-blue-600 mb-2">24/7</div>
                    <div class="text-gray-600">Community Support</div>
                </div>
                <div class="p-6">
                    <div class="text-4xl font-bold text-blue-600 mb-2">1.0s</div>
                    <div class="text-gray-600">Avg. Response Time</div>
                </div>
            </div>
        </div>
    </section>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        // Smooth scrolling for anchor links
        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
            anchor.addEventListener('click', function (e) {
                e.preventDefault();
                const targetId = this.getAttribute('href');
                if (targetId === '#') return;
                
                const targetElement = document.querySelector(targetId);
                if (targetElement) {
                    window.scrollTo({
                        top: targetElement.offsetTop - 80,
                        behavior: 'smooth'
                    });
                }
            });
        });
    </script>
{% endblock %}
