# EditorConfig is awesome: https://EditorConfig.org

# top-most EditorConfig file
root = true

# Unix-style newlines with a newline ending every file
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

# PHP files
[*.php]
indent_style = space
indent_size = 4

# JavaScript/TypeScript/JSON/YAML files
[*.{js,jsx,ts,tsx,json,yml,yaml}]
indent_style = space
indent_size = 2

# Markdown files
[*.md]
trim_trailing_whitespace = false

# Composer files
[composer.json]
indent_style = space
indent_size = 4

# Twig templates
[*.twig]
indent_style = space
indent_size = 4

# XML files
[*.xml]
indent_style = space
indent_size = 4

# CSS/SCSS files
[*.{css,scss}]
indent_style = space
indent_size = 2

# Shell scripts
[*.sh]
indent_style = tab
indent_size = 4

# Git merge files
[*.orig]
charset = unset

# Docker files
[Dockerfile*]
indent_style = space
indent_size = 4

# Ignore package files
[package-lock.json]
indent_style = space
indent_size = 2

# Ignore minified files
[*.min.{js,css}]
indent_style = ignore
indent_size = ignore

# Ignore generated files
[dist/**]
indent_style = ignore
indent_size = ignore

# Ignore vendor directory
[vendor/**]
indent_style = ignore
indent_size = ignore

# Ignore node_modules
[node_modules/**]
indent_style = ignore
indent_size = ignore

# Ignore build artifacts
[build/**]
indent_style = ignore
indent_size = ignore

# Ignore coverage reports
[coverage/**]
indent_style = ignore
indent_size = ignore
