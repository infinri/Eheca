{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Eheca Project Rules",
  "version": "1.0.0",
  "description": "Project-specific rules for Eheca Framework development that extend and complement global and God Tier rules.",
  
  "inherits": [
    "~/.codeium/windsurf/memories/god_rule_tier1.md",
    "~/.codeium/windsurf/memories/god_rule_tier2.md",
    "~/.codeium/windsurf/memories/god_rule_tier3.md",
    "~/.codeium/windsurf/memories/god_rule_tier4.md"
  ],
  
  "project": {
    "name": "Eheca Framework",
    "type": "php-framework",
    "repository": "git@github.com:infinri/Eheca.git",
    "documentation": "./docs/"
  },
  
  "code_style": {
    "php": {
      "standard": "PSR-12",
      "php_version": "8.2+",
      "strict_types": true,
      "line_length": 120,
      "indent_style": "space",
      "indent_size": 4,
      "final_classes": true,
      "declare_strict_types": true,
      "type_declarations": {
        "property": true,
        "return": true,
        "parameter": true
      }
    },
    "javascript": {
      "standard": "airbnb",
      "version": "ES2022"
    },
    "twig": {
      "indent": 2,
      "whitespace_trim": "-",
      "tag_comment": ["{#", "#}"],
      "tag_block": ["{%", "%}"],
      "tag_variable": ["{{", "}}"]
    },
    "xml": {
      "indent": 2,
      "self_closing_elements": true
    }
  },
  
  "architecture": {
    "pattern": "modular",
    "module_structure": {
      "required_dirs": ["Controller", "Model", "view", "etc"],
      "required_files": ["registration.php", "etc/module.xml"],
      "naming_convention": "PascalCase"
    },
    "layers": ["Presentation", "Service", "Domain", "Infrastructure"],
    "bounded_contexts": ["Core", "Admin", "Api", "Checkout"],
    "dependencies": {
      "core": [],
      "external": [
        {"name": "php", "version": "^8.2"},
        {"name": "twig/twig", "version": "^3.0"},
        {"name": "symfony/dependency-injection", "version": "^6.0"},
        {"name": "monolog/monolog", "version": "^2.0"}
      ]
    }
  },
  
  "performance": {
    "memory_limit": "256M",
    "max_execution_time": 30,
    "database": {
      "query_timeout": 5,
      "max_connections": 100,
      "connection_timeout": 5
    },
    "caching": {
      "enabled": true,
      "default_ttl": 3600,
      "adapter": "filesystem",
      "pools": ["default", "page_cache", "eav"]
    },
    "optimization": {
      "opcache": true,
      "preload": true,
      "jit": true,
      "static_analysis": true
    }
  },
  
  "security": {
    "authentication": {
      "method": "jwt",
      "token_ttl": 3600,
      "refresh_token_ttl": 2592000,
      "password_hashing": "argon2id"
    },
    "headers": {
      "content_security_policy": "default-src 'self'",
      "strict_transport_security": "max-age=31536000; includeSubDomains",
      "x_content_type_options": "nosniff",
      "x_frame_options": "SAMEORIGIN",
      "x_xss_protection": "1; mode=block"
    },
    "input_validation": {
      "enabled": true,
      "xss_protection": true,
      "csrf_protection": true,
      "sql_injection_protection": true
    }
  },
  
  "testing": {
    "frameworks": ["phpunit"],
    "coverage": {
      "minimum": 80,
      "critical": ["Controller", "Model"],
      "exclude": ["tests/", "setup/", "generated/"]
    },
    "types": ["unit", "integration", "functional", "api"],
    "database": {
      "fixtures": true,
      "migrations": true,
      "rollback": true
    }
  },
  
  "documentation": {
    "required_sections": ["README.md", "CONTRIBUTING.md", "CHANGELOG.md"],
    "api": {
      "generator": "phpdoc",
      "output": "./docs/api",
      "theme": "clean"
    },
    "diagrams": {
      "types": ["uml", "sequence", "er"],
      "format": "svg",
      "output": "./docs/diagrams"
    }
  },
  
  "deployment": {
    "environments": {
      "development": {
        "url": "dev.eheca.test",
        "branch": "develop"
      },
      "staging": {
        "url": "staging.eheca.app",
        "branch": "staging"
      },
      "production": {
        "url": "eheca.app",
        "branch": "main"
      }
    },
    "containers": {
      "enabled": true,
      "orchestration": "docker-compose",
      "images": ["php-fpm", "nginx", "mysql", "redis"]
    },
    "ci_cd": {
      "provider": "github-actions",
      "stages": ["test", "build", "deploy"],
      "notifications": ["slack", "email"]
    }
  },
  
  "ai_assistance": {
    "context": {
      "include": [
        "app/code",
        "app/design",
        "app/etc/config.php",
        "composer.json"
      ],
      "exclude": [
        "var/",
        "generated/",
        "node_modules/",
        "vendor/"
      ]
    },
    "autofix": {
      "enabled": true,
      "level": "suggested",
      "require_review": true
    },
    "suggestions": {
      "documentation": true,
      "tests": true,
      "refactoring": true,
      "performance": true,
      "security": true
    }
  },
  
  "compliance": {
    "licenses": ["MIT"],
    "vulnerability_scanning": true,
    "dependencies": {
      "allow_alpha": false,
      "allow_beta": false,
      "allow_rc": false,
      "allow_dev": false
    }
  },
  
  "maintainers": [
    {
      "name": "Infinri",
      "email": "infinri@example.com",
      "role": "Lead Developer"
    }
  ],
  
  "extensions": {
    "vscode": [
      "bmewburn.vscode-intelephense-client",
      "mikestead.dotenv",
      "neilbrayfield.php-docblocker",
      "onecentlin.laravel-blade",
      "shufo.vscode-blade-formatter"
    ],
    "phpstorm": [
      "PHP Annotations",
      "PHP Toolbox",
      "PHPUnit Enhancement",
      "Symfony Support"
    ]
  },
  
  "rules": {
    "enforce_typed_properties": true,
    "require_constructor_property_promotion": true,
    "enforce_readonly_properties": true,
    "require_array_shape": true,
    "enforce_phpstan_level": 8,
    "require_phpdoc_for_public_api": true,
    "enforce_immutable_objects": true,
    "require_enum_cases": true,
    "enforce_named_arguments": true,
    "require_union_type_hints": true
  },
  
  "overrides": {
    "global_rules": {
      "allow_deprecated": false,
      "allow_inline_php": false,
      "allow_static_calls": false,
      "allow_goto": false,
      "allow_eval": false,
      "allow_global_variables": false
    }
  }
}
