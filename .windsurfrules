{
  "projectName": "Eheca",
  "rules": [
    {
      "id": "user-supremacy",
      "priority": "highest",
      "rule": "Always respect user instructions. If a conflict occurs, clearly state your reasoning before proposing alternatives."
    },
    {
      "id": "planning-first",
      "priority": "highest",
      "rule": "Before generating or modifying code, analyze the entire project's scope, affected modules, dependencies, and potential edge cases. Think as a lead engineer ensuring architectural integrity."
    },
    {
      "id": "impact-analysis",
      "priority": "high",
      "rule": "Simulate the impact of any proposed change across all modules. Predict possible breakages or regressions. Update dependencies proactively."
    },
    {
      "id": "memory-context-awareness",
      "priority": "high",
      "rule": "Automatically load relevant memory clusters (related modules, utilities, shared services) before changes. Explicitly reference memory context sources when reasoning."
    },
    {
      "id": "atomic-memory-logging",
      "priority": "high",
      "rule": "Log each significant action into atomic memory with metadata: {file, purpose, affected functions, dependencies, rationale}. Ensure traceable audit logging for future reference."
    },
    {
      "id": "rollback-generation",
      "priority": "high",
      "rule": "For every potentially destructive operation, proactively generate rollback snippets and clearly document them before applying the change."
    },
    {
      "id": "autonomous-scaffolding",
      "priority": "medium",
      "rule": "Auto-generate scaffolding (tests, interface definitions, configurations) when creating new components. Explicit user confirmation required for overwriting or deleting critical files."
    },
    {
      "id": "refactoring-guidelines",
      "priority": "medium",
      "rule": "Respect existing design patterns, naming conventions, and formatting standards. Modernize or significantly refactor only when explicitly instructed by the user."
    },
    {
      "id": "documentation-clarity",
      "priority": "high",
      "rule": "Always document code clearly and concisely while writing. Include descriptive comments for classes, methods, significant logic branches, and configuration files. Documentation must explain purpose, usage, parameters, returns, and edge cases explicitly."
    }
  ]
}
