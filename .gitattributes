# Auto detect text files and perform LF normalization
* text=auto eol=lf

# Force these files to always use LF line endings
*.sh text eol=lf
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary files should not be modified
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.ttf binary
*.woff binary
*.woff2 binary
*.eot binary
*.pdf binary
*.zip binary
*.gz binary
*.bz2 binary
*.exe binary
*.dll binary
*.so binary
*.dylib binary

# Documentation
*.md text
*.txt text
*.json text
*.yaml text
*.yml text
*.xml text
*.dist text
*.md.orig text
*.txt.orig text

# Source code
*.php text
*.js text
*.jsx text
*.ts text
*.tsx text
*.css text
*.scss text
*.sass text
*.less text
*.html text
*.twig text
*.sql text

# Lock files should maintain CRLF line endings
composer.lock -text
package-lock.json -text
yarn.lock -text

# Don't ignore whitespace for these files
*.php -whitespace
*.js -whitespace
*.jsx -whitespace
*.ts -whitespace
*.tsx -whitespace
*.css -whitespace
*.scss -whitespace
*.sass -whitespace
*.less -whitespace
*.html -whitespace
*.twig -whitespace
*.sql -whitespace

# Export-ignore files that should not be included in the distribution
/.github export-ignore
/.gitattributes export-ignore
/.gitignore export-ignore
/.editorconfig export-ignore
/phpcs.xml export-ignore
/phpstan.neon export-ignore
/phpunit.xml.dist export-ignore
/README.md export-ignore
/CHANGELOG.md export-ignore
/CONTRIBUTING.md export-ignore
/SECURITY.md export-ignore
/tests export-ignore
/docs export-ignore
/var export-ignore

# Custom merge drivers
*.php merge=union
*.js merge=union
*.jsx merge=union
*.ts merge=union
*.tsx merge=union
*.css merge=union
*.scss merge=union
*.sass merge=union
*.less merge=union
*.html merge=union
*.twig merge=union
*.sql merge=union

