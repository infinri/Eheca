<?xml version="1.0"?>
<ruleset name="Eheca">
    <description>Coding standard for the Eheca project</description>

    <!-- Display progress -->
    <arg value="sp"/>

    <!-- Show sniff and source of warnings/errors -->
    <arg value="s"/>

    <!-- Paths to check -->
    <file>src</file>
    <file>tests</file>
    <file>config</file>
    <file>public</file>

    <!-- Exclude directories -->
    <exclude-pattern>*/vendor/*</exclude-pattern>
    <exclude-pattern>*/var/*</exclude-pattern>
    <exclude-pattern>*/node_modules/*</exclude-pattern>
    <exclude-pattern>*/cache/*</exclude-pattern>

    <!-- Include the PSR-12 standard -->
    <rule ref="PSR12">
        <!-- Exclude PSR1.Methods.CamelCapsMethodName for test methods -->
        <exclude name="PSR1.Methods.CamelCapsMethodName"/>
    </rule>

    <!-- Additional rules -->
    <rule ref="Generic.PHP.Syntax"/>
    <rule ref="Squiz.Commenting.FunctionComment">
        <properties>
            <property name="specialMethods" type="array" value="__construct,setUp,tearDown"/>
        </properties>
    </rule>

    <!-- Line length -->
    <rule ref="Generic.Files.LineLength">
        <properties>
            <property name="lineLimit" value="120"/>
            <property name="absoluteLineLimit" value="120"/>
        </properties>
    </rule>

    <!-- Allow @var for inline @var annotations -->
    <rule ref="Squiz.Commenting.InlineComment">
        <properties>
            <property name="requiredSpacesAfter" value="1"/>
        </properties>
    </rule>

    <!-- Allow Yoda conditions in tests -->
    <rule ref="Generic.ControlStructures.DisallowYodaConditions">
        <exclude-pattern>*/tests/*</exclude-pattern>
    </rule>

    <!-- Exclude some common false-positives -->
    <rule ref="Squiz.WhiteSpace.SuperfluousWhitespace">
        <properties>
            <property name="ignoreBlankLines" value="false"/>
        </properties>
    </rule>
    <rule ref="Squiz.WhiteSpace.SuperfluousWhitespace.StartFile">
        <severity>0</severity>
    </rule>
    <rule ref="Squiz.WhiteSpace.SuperfluousWhitespace.EndFile">
        <severity>0</severity>
    </rule>
    <rule ref="Squiz.WhiteSpace.SuperfluousWhitespace.EmptyLines">
        <severity>0</severity>
    </rule>

    <!-- Allow empty catch blocks with comment -->
    <rule ref="Generic.CodeAnalysis.EmptyStatement">
        <properties>
            <property name="allowEmptyCatch" value="true"/>
        </properties>
    </rule>

    <!-- Allow unused parameters in tests -->
    <rule ref="SlevomatCodingStandard.Functions.UnusedParameter">
        <exclude-pattern>*/tests/*</exclude-pattern>
    </rule>

    <!-- Allow unused use statements in tests -->
    <rule ref="SlevomatCodingStandard.Namespaces.UnusedUses">
        <exclude-pattern>*/tests/*</exclude-pattern>
    </rule>

    <!-- Ignore PHP version specific code -->
    <rule ref="Generic.PHP.DeprecatedFunctions">
        <exclude-pattern>*/tests/*</exclude-pattern>
    </rule>
</ruleset>
